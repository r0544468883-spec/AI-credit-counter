{
  "manifest_version": 3,
  "name": "AI-Flow Monitor",
  "version": "1.3.0",
  "description": "Track your AI credits across ChatGPT, Claude, Gemini, DALL-E, Midjourney, Runway, Perplexity and more",
  "permissions": ["activeTab", "storage", "tabs", "notifications"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://platform.openai.com/*"
      ],
      "js": ["content-chatgpt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content-claude.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content-gemini.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://discord.com/*"],
      "js": ["content-discord.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://app.runwayml.com/*",
        "https://runwayml.com/*"
      ],
      "js": ["content-runway.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*"
      ],
      "js": ["content-perplexity.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
